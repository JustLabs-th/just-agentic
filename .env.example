# ── Database (required) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://just_agentic:just_agentic@localhost:5432/just_agentic

# ── LLM Provider: openai | openrouter | anthropic | ollama | vllm ─────────────
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# OpenRouter (dev-friendly, access to many models)
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama (local)
# OLLAMA_MODEL=qwen2.5-coder

# vLLM (self-hosted)
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct
# VLLM_API_KEY=EMPTY

# ── Agent config ──────────────────────────────────────────────────────────────
MAX_ITERATIONS=8
CONFIDENCE_THRESHOLD=0.55
WORKSPACE_ROOT=/absolute/path/to/your/project

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production

# ── Phase 1: Redis + Worker Queue ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Phase 2: Tool Execution Service ───────────────────────────────────────────
# Set in Docker — worker routes run_shell / execute_python / run_tests here
# TOOL_SERVICE_URL=http://tool-service:8001
TOOL_SERVICE_SECRET=change-me-in-production

# Sandbox resource limits (inside tool-service subprocess)
# SANDBOX_CPU_SOFT=30
# SANDBOX_CPU_HARD=60
# SANDBOX_MEM_MB=512
# SANDBOX_FSIZE_MB=50
# SANDBOX_NPROC=64
